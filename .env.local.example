# ============================================================
# ZENITH CONNECT — Environment Variables
# Copy to .env.local — NEVER COMMIT .env.local
# ============================================================

# Supabase (get from: supabase.com > project settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OpenRouter (free OSS models — llama3, mistral, gemma, etc.)
# Get key at: openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Default model (change to any free OpenRouter model)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Trystero (room namespace — your app's unique ID)
NEXT_PUBLIC_TRYSTERO_APP_ID=zenith-connect-v1
# Strategy: nostr (default) | torrent | mqtt | firebase | supabase
NEXT_PUBLIC_TRYSTERO_STRATEGY=nostr

# MapLibre / Map tiles (free: protomaps, maptiler free tier)
# Get free key at: maptiler.com/cloud
NEXT_PUBLIC_MAPTILER_KEY=your_maptiler_key

# TURN server (optional self-hosted coturn, or use Metered free tier)
NEXT_PUBLIC_TURN_URL=turn:global.relay.metered.ca:80
TURN_USERNAME=your_turn_username
TURN_CREDENTIAL=your_turn_credential

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Zenith Connect
